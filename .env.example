# ============================================
# Swing Trader — Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys.
# See setup guide at bottom for registration links.

# --- Anthropic (Claude AI) ---
# Already in ~/.env if you use Claude Code
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Alpaca (Paper Trading) ---
# Register: https://alpaca.markets (free paper trading)
# Go to: Dashboard → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Finnhub (News + Earnings) ---
# Register: https://finnhub.io (free tier: 60 calls/min)
FINNHUB_API_KEY=your_finnhub_api_key

# --- Financial Modeling Prep (Fundamentals) ---
# Register: https://financialmodelingprep.com (free tier: 250 calls/day)
FMP_API_KEY=your_fmp_api_key

# --- Alpha Vantage (Backup Financial Data) ---
# Register: https://www.alphavantage.co/support/#api-key (free: 25 calls/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# --- FRED (Macro Indicators) ---
# Register: https://fred.stlouisfed.org/docs/api/api_key.html (free, unlimited)
FRED_API_KEY=your_fred_api_key

# --- Telegram Bot ---
# 1. Message @BotFather on Telegram, send /newbot, follow prompts
# 2. Copy the bot token below
# 3. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id in the response JSON
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Reddit (Sentiment Scanning) ---
# Register: https://www.reddit.com/prefs/apps (create "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SwingTrader/1.0

# --- Database ---
DATABASE_URL=sqlite:///swing_trader.db
