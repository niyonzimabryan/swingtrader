# ============================================
# Swing Trader - Environment Configuration
# ============================================
# Recommended setup:
#   python -m scripts.setup_wizard
#
# Manual setup:
#   cp .env.example .env
#   Fill every required core/trading/data key below.
#
# Gemini is the only research key intentionally treated as an optional add-on.

# --- Core AI: required ---
# Claude runs the core analysis, scoring, memo writing, and Anthropic web search.
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Telegram: required ---
# 1. Message @BotFather on Telegram.
# 2. Send /newbot and follow the prompts.
# 3. Paste the generated token below.
# 4. Send /start to your new bot.
# 5. The setup wizard can discover TELEGRAM_CHAT_ID automatically.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Alpaca paper trading: required ---
# Register: https://app.alpaca.markets
# Use Paper Trading keys only.
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Broker and execution mode ---
# Modes:
#   review_only = broker review/audit only, no placement
#   paper       = Alpaca paper placement
#   live        = primary broker placement when ALLOW_LIVE_TRADING=true
BROKER_PRIMARY=alpaca
BROKER_PAPER=alpaca
EXECUTION_MODE=paper
ALLOW_LIVE_TRADING=false
REQUIRE_ORDER_REVIEW=true

# --- Robinhood Agentic Trading MCP ---
# Robinhood live trading uses a dedicated Agentic account through MCP.
# Do not commit OAuth tokens. Prefer local MCP/OAuth auth; auth token/header
# knobs exist only for service-side deployments with a managed token store.
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_ACCOUNT_NUMBER=
ROBINHOOD_MCP_AUTH_TOKEN=
ROBINHOOD_MCP_HEADERS_JSON=
# Fernet key for the encrypted OAuth token store (database/token_store.py).
# Generate: python -m scripts.robinhood_auth --gen-key
# Set as a Railway SEALED variable; back it up out-of-band (loss => re-auth).
TOKEN_ENCRYPTION_KEY=
ROBINHOOD_ACCOUNT_BUDGET=25
ROBINHOOD_MAX_ORDER_NOTIONAL=5
ROBINHOOD_MAX_DAILY_NOTIONAL=10
ROBINHOOD_MAX_OPEN_POSITIONS=3
ROBINHOOD_ALLOW_FRACTIONAL=true
ROBINHOOD_ALLOW_OPTIONS=false
ROBINHOOD_ALLOWED_SYMBOLS=
ROBINHOOD_BLOCKED_SYMBOLS=
ROBINHOOD_ORDER_TYPE=market
ROBINHOOD_MARKET_HOURS=regular_hours
ALPACA_ENABLED=true
ALPACA_PAPER_ONLY=true

# --- Market/data providers: required ---
# Finnhub: news, earnings, analyst recommendations, price targets.
# Register: https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_api_key

# Financial Modeling Prep: fundamentals and pattern-data fallback coverage.
# Register: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key

# Alpha Vantage: backup financial data provider.
# Register: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# FRED: macro rates, yield curve, and credit spread inputs.
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# --- Runtime: required ---
DATABASE_URL=sqlite:///swing_trader.db

# Start with scheduler disabled while validating Telegram and paper trading.
# Set true after /test AAPL works.
SCHEDULER_ENABLED=false

# --- Trading/risk defaults: optional tuning ---
PORTFOLIO_VALUE=100000.0
BASE_POSITION_PCT=0.05
MAX_POSITION_PCT=0.10
MIN_POSITION_PCT=0.02
MAX_PORTFOLIO_EXPOSURE=0.80
MAX_SECTOR_EXPOSURE=0.30
MAX_CONCURRENT_POSITIONS=8
DEFAULT_STOP_LOSS_PCT=0.05
MAX_STOP_LOSS_PCT=0.08
MAX_HOLDING_DAYS=20
DRAWDOWN_CIRCUIT_BREAKER_PCT=0.10
DAILY_LOSS_HALT_PCT=0.03

# --- Scoring/model defaults: optional tuning ---
MEMO_THRESHOLD=0.55
HIGH_CONVICTION_THRESHOLD=0.75
CATALYST_ESCALATION_THRESHOLD=3
SCORING_MODEL=claude-opus-4-6
ANALYST_MODEL=claude-sonnet-4-6
FILTER_MODEL=claude-haiku-4-5-20251001

# --- Schedule defaults: optional tuning, Eastern Time hours ---
PRE_MARKET_HOUR=7
MIDDAY_HOUR=12
POST_MARKET_HOUR=17
SCHEDULER_MISFIRE_GRACE_TIME_S=7200

# --- Gemini add-on: optional, recommended for search-heavy stages ---
# By default, discovery and web research use Gemini Pro + Google Search grounding.
# If GEMINI_API_KEY is blank, the app can fall back to Anthropic web search.
# Register: https://aistudio.google.com/app/apikey
WEB_SEARCH_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_SEARCH_MODEL=gemini-3.1-pro-preview
GEMINI_DISCOVERY_MODEL=gemini-3.1-pro-preview
GEMINI_WEB_RESEARCH_MODEL=gemini-3.1-pro-preview
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_FLASH_ESCALATION_THRESHOLD=0.50
DISCOVERY_MAX_TICKERS=12
DISCOVERY_MODEL=claude-sonnet-4-6
DISCOVERY_OUTPUT_MAX_TOKENS=8192
DISCOVERY_MAX_SEARCHES=8
DISCOVERY_THINKING_BUDGET=0
OPUS_THINKING_BUDGET=16000
WEB_RESEARCH_MAX_SEARCHES=5
WEB_RESEARCH_CACHE_ENABLED=true
WEB_RESEARCH_CACHE_TTL_HOURS=24
DEEP_RESEARCH_PROVIDER=gemini
DEEP_RESEARCH_SCORE_THRESHOLD=0.75

# --- Watchlist defaults: optional tuning ---
WATCHLIST_HAIKU_THRESHOLD=2
WATCHLIST_MAX_SIZE=25

# --- Firecrawl: optional narrative scraper + paywall fallback ---
# Used by web research + catalyst agents to fetch full article bodies (earnings
# transcripts, paywalled news). Free tier covers typical use (~50 calls/day).
# Without this key the agents fall back to grounded LLM search and headline-only
# catalyst summaries — SwingTrader runs fine, narrative depth is reduced.
# Register: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
FIRECRAWL_MAX_CALLS_PER_SCAN=50
ARCHIVE_IS_ENABLED=true

# --- Langfuse observability: optional ---
# Register: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- Advanced/future integrations: optional ---
# OpenAI deep research is not required by the current setup path.
OPENAI_API_KEY=

# Legacy Reddit sentiment adapter. Current research flow does not require it.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SwingTrader/1.0

# --- Pipeline parallelization defaults ---
PARALLEL_AGENTS_ENABLED=true
PARALLEL_AGENTS_SCOPE=both
PARALLEL_WORKERS_DEFAULT=3
PARALLEL_WORKERS_DEGRADED=2
PARALLEL_TIMEOUT_FUNDAMENTAL_S=180
PARALLEL_TIMEOUT_PATTERN_S=300
PARALLEL_TIMEOUT_WEB_RESEARCH_S=300

# --- Parallel stability controller defaults ---
PARALLEL_AUTO_DEGRADE_ENABLED=true
PARALLEL_BAD_RUN_WINDOW=12
PARALLEL_BAD_RUN_COUNT_TRIGGER=3
PARALLEL_COOLDOWN_RUNS=20
PARALLEL_RECOVERY_GOOD_RUNS=8
PARALLEL_ALERT_ON_STATE_CHANGE=true
